model User {
  id             String        @id @default(cuid())
  firebaseUid    String        @unique
  name           String
  sex            Sex
  height         Float         // cm
  dateOfBirth    DateTime
  targetWeightKg Float
  activityLevel  ActivityLevel @default(SEDENTARY)

  // Goals
  dailyDeficitKcal Float  // daily deficit target in kcal (e.g. 400)
  targetProtein     Float  // g
  targetCarbs       Float  // g
  targetFat         Float  // g

  weightEntries   WeightEntry[]
  dailyLogs       DailyLog[]
  weekSummaries   WeekSummary[]
  activityEntries ActivityEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY      // Desk job, car commute, minimal daily movement
  LIGHTLY_ACTIVE // On feet regularly — retail, teaching, nursing, walking commute
}