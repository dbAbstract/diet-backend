enum ActivitySource {
  AI_ESTIMATED
  WHOOP
  MANUAL
}

model ActivityEntry {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id])
  userId      String
  date        DateTime       @db.Date
  description String
  kcalBurned  Float
  source      ActivitySource

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
